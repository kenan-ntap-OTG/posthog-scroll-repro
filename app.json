{
  "expo": {
    "name": "posthog-scroll-repro",
    "slug": "posthog-scroll-repro",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "posthogscrollrepro",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kenanntap.posthogscrollrepro"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.kenanntap.posthogscrollrepro"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
